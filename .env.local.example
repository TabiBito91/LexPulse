# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local — it is in .gitignore.

# --- Clerk ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Comma-separated GitHub usernames allowed to access the app
ALLOWED_USERS=your-github-username,tester2

# --- Encryption ---
# 32-byte hex string. Generate with: openssl rand -hex 32
# CRITICAL: never prefix with NEXT_PUBLIC_ — would expose to client
KEY_ENCRYPTION_SECRET=

# --- Anthropic ---
# Owner's key — used only for cron-triggered digest
ANTHROPIC_API_KEY=sk-ant-...

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
# Service role key — server-side only, never expose to client
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Cron ---
# Random secret to authenticate Vercel cron requests
# Generate with: openssl rand -hex 32
CRON_SECRET=

# --- Feature flags ---
ENABLE_VERIFICATION=false
